<?xml version="1.0"?>
<!--  This launch file runs the robot_localization node which
      combines the odometry, gyroscope, and accelerometer outputs
      a smoothed estimate of the global robot pose  -->

<launch>
  <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se" clear_params="true">
    <rosparam command="load" file="$(find jet_launcher)/params/ekf_template.yaml" />

    <!--  Placeholder for output topic remapping -->
    <remap from="odometry/filtered" to="/ekf_node/odom"/>
    <remap from="accel/filtered" to="/ekf_node/accel"/>

  </node>
  <include file="$(find imu_bno055)/launch/imu.launch" />

  <!-- <include file="$(find imu_bno055)/launch/gps.launch" /> -->
</launch>

