<launch>
   <node pkg="tf2_ros" type="static_transform_publisher" name="base_link" args="0 0 0 0 0 0 1 map base_link" />
   <node pkg="tf2_ros" type="static_transform_publisher" name="link1_broadcaster" args="1.5 0 .5 0 0 0 1 base_link link1" />
    <node pkg="image_test" type="range_data_publisher.py" name="range_node" cwd="node" output="screen">
    </node>
</launch>
