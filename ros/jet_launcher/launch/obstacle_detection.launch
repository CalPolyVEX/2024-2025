<?xml version="1.0"?>
<launch>
  <node pkg="nodelet" type="nodelet" name="pcl_manager" args="manager" output="screen" />

  <!-- Run a VoxelGrid filter to clean NaNs and downsample the data -->
  <node pkg="nodelet" type="nodelet" name="voxel_grid" args="load pcl/VoxelGrid pcl_manager" output="screen">
    <remap from="~input" to="/zed/zed_node/point_cloud/cloud_registered" /> 
    <!-- <remap from="~input" to="/zed/throttled_point_cloud" />  -->
    <rosparam>
      filter_field_name: z
      filter_limit_min: -0.8
      filter_limit_max: 0.0
      filter_limit_negative: False
      leaf_size: 0.05
    </rosparam>
  </node>

  <node pkg="nodelet" type="nodelet" name="obstacles_detection" args="load rtabmap_ros/obstacles_detection pcl_manager" output="screen">
      <!--<remap from="cloud"     to="/zed/point_cloud_transformed"/> -->
      <remap from="cloud"     to="/voxel_grid/output"/>
      <remap from="obstacles" to="/obstacles_cloud"/>
      <remap from="ground"    to="/ground_cloud"/>
      
      <param name="frame_id"             type="string" value="base_link"/>	
      <param name="map_frame_id"         type="string" value="map"/>
      <param name="wait_for_transform"   type="bool" value="false"/>
      <param name="Grid/MinClusterSize"     type="int" value="20"/> 
      <param name="Grid/MaxObstaclesHeight" type="double" value="0.4"/> 
  </node>   
</launch>
