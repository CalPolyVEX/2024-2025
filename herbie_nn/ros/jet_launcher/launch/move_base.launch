<?xml version="1.0"?>
<launch>
   <include file="$(find jet_launcher)/launch/tf_publisher.launch"/>

   <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find jet_launcher)/launch/common_costmap_params.yaml" command="load" ns="global_costmap" /> 
    <rosparam file="$(find jet_launcher)/launch/common_costmap_params.yaml" command="load" ns="local_costmap" /> 
    <rosparam file="$(find jet_launcher)/launch/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find jet_launcher)/launch/global_costmap_params.yaml" command="load" />
    <rosparam file="$(find jet_launcher)/launch/base_local_planner_params.yaml" command="load" />

    <!-- <rosparam file="$(find jet_launcher)/launch/teb_planner_params.yaml" command="load" />  
    <param name="base_local_planner" value="teb_local_planner/TebLocalPlannerROS" /> --> -->
    <param name="controller_frequency" value="10.0" /> -->
 </node>
</launch>
