<?xml version="1.0"?>

<launch>
<arg name="testing_map" default="false" />

<param name="/rtabmap/rtabmap/Reg/Force3DoF"         value="true"  /> 
<param name="/rtabmap/rtabmap/Grid/RayTracing"       value="true"  />  
<param name="/rtabmap/rtabmap/Grid/3D"               value="false" />  
<param name="/rtabmap/rtabmap/Grid/RangeMax"         value="5.0"   />  
<param name="/rtabmap/rtabmap/Mem/DepthAsMask"       value="true"  />  

<param name="/rtabmap/rtabmap/Kp/DetectorStrategy"   value="8"     /> <!-- use GFTT/ORB -->  

<group if="$(arg testing_map)">
    <param name="/rtabmap/rtabmap/GFTT/BlockSize"        value="10"     />  
    <param name="/rtabmap/rtabmap/GFTT/MinDistance"      value="10"     />  
    <param name="/rtabmap/rtabmap/GFTT/QualityLevel"     value=".0005"  />  
</group>
<group unless="$(arg testing_map)">
    <param name="/rtabmap/rtabmap/GFTT/BlockSize"        value="5"     />  
    <param name="/rtabmap/rtabmap/GFTT/MinDistance"      value="6"     />  
    <param name="/rtabmap/rtabmap/GFTT/QualityLevel"     value=".0007"  />  
</group>

<!-- <param name="/rtabmap/rtabmap/Mem/InitWMWithAllNodes"     value="false"  /> -->  
<!-- <param name="/rtabmap/rtabmap/Rtabmap/MemoryThr"     value="1000"  /> -->  
<!-- <param name="/rtabmap/rtabmap/Rtabmap/TimeThr"     value="800"  /> -->  
<param name="/rtabmap/rtabmap/RGBD/SavedLocalizationIgnored"     value="true"  />  

<!-- RTAB-Map's parameters -->
<param name="/rtabmap/rtabmap/RGBD/NeighborLinkRefining" type="string" value="true"/>
<param name="/rtabmap/rtabmap/RGBD/ProximityBySpace"     type="string" value="true"/>
<param name="/rtabmap/rtabmap/RGBD/ProximityPathMaxNeighbors" type="string" value="10"/>
<param name="/rtabmap/rtabmap/RGBD/AngularUpdate"        type="string" value="0.01"/>
<param name="/rtabmap/rtabmap/RGBD/LinearUpdate"         type="string" value="0.01"/>
<param name="/rtabmap/rtabmap/RGBD/OptimizeFromGraphEnd" type="string" value="false"/>
<param name="/rtabmap/rtabmap/Grid/FromDepth"            type="string" value="false"/> <!-- occupancy grid from lidar -->
<param name="/rtabmap/rtabmap/Reg/Force3DoF"             type="string" value="true"/>
<param name="/rtabmap/rtabmap/Reg/Strategy"              type="string" value="1"/> <!-- 1=ICP -->

<!-- ICP parameters -->
<param name="Icp/VoxelSize"                 type="string" value="0.05"/>
<param name="Icp/MaxCorrespondenceDistance" type="string" value="0.1"/>

</launch>
