<?xml version="1.0"?>
<launch>
  <node pkg="nodelet" type="nodelet" name="depth_to_laser" args="load depthimage_to_laserscan/DepthImageToLaserScanNodelet zed_nodelet_manager" output="screen">
    <remap from="image"     to="/zed_node/depth/depth_registered"/>
    <remap from="camera_info" to="/zed_node/rgb/camera_info"/>
    <remap from="scan" to="/depth_to_laser/scan"/>

    <param name="output_frame_id"         type="string" value="zed_camera_center"/>	
    <param name="scan_height"             type="int" value="200"/>	
    <param name="range_min"             type="double" value=".01"/>	
    <param name="range_max"             type="double" value="8.0"/>	
    <param name="scan_time"             type="double" value=".05"/>	
  </node>
</launch>
